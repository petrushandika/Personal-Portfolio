---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Blog - Portfolio">
  <main class="container mx-auto px-4 py-16">
    <h1 class="text-4xl font-bold mb-8 text-center">Blog</h1>
    
    <div id="articles-grid" class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
      <!-- Articles will be loaded here -->
    </div>
  </main>
</BaseLayout>

<script>
  const API_URL = import.meta.env.PUBLIC_API_URL || 'http://localhost:3001/api';
  
  async function loadArticles() {
    try {
      const response = await fetch(`${API_URL}/articles?status=published&limit=9`);
      const { data } = await response.json();
      
      const grid = document.getElementById('articles-grid');
      if (!grid) return;
      
      if (!data || data.length === 0) {
        grid.innerHTML = '<p class="col-span-full text-center text-gray-500">Belum ada artikel</p>';
        return;
      }
      
      grid.innerHTML = data.map((article: any) => `
        <article class="card overflow-hidden">
          ${article.featuredImage ? `<img src="${article.featuredImage}" alt="${article.title}" class="w-full h-48 object-cover" />` : ''}
          <div class="p-6">
            <h2 class="text-xl font-semibold mb-2">
              <a href="/blog/${article.slug}" class="hover:text-primary-500">${article.title}</a>
            </h2>
            <p class="text-gray-600 mb-4 line-clamp-3">${article.excerpt}</p>
            <time class="text-sm text-gray-500">
              ${new Date(article.publishedAt).toLocaleDateString('id-ID', { dateStyle: 'long' })}
            </time>
          </div>
        </article>
      `).join('');
    } catch (error) {
      console.error('Failed to load articles:', error);
    }
  }
  
  loadArticles();
</script>
