---
import { ArticlesShowcase } from '../components/main/ArticlesShowcase';
import { Hero } from '../components/main/Hero';
import { ProjectsShowcase } from '../components/main/ProjectsShowcase';
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout 
  title="Petrus Handika - Full Stack Developer"
  description="Portfolio of Petrus Handika, a Full Stack Developer specializing in React, Next.js, Node.js, and modern web technologies."
>
  <main>
    <Hero />

    <section id="projects" class="py-24 relative mt-16">
      <div class="container mx-auto px-4 md:px-8 relative z-10">
        <div class="text-center md:text-left mb-16 flex flex-col md:flex-row md:items-end gap-6 border-b border-white/10 pb-6">
          <h2 class="text-4xl md:text-5xl font-bold text-gray-100 tracking-tight flex items-center gap-4">
            <span class="text-brand-400 font-mono text-xl md:text-2xl font-normal">02.</span> 
            Featured Projects
          </h2>
          <div class="hidden md:block w-px h-8 bg-white/10 ml-4"></div>
          <span class="text-brand-400 font-mono text-sm tracking-wide">
            Some things I've built
          </span>
        </div>
        
        <div class="w-full">
          <ProjectsShowcase client:visible limit={6} />
          
          <div class="text-center mt-12">
            <a 
              href="/projects" 
              class="btn-secondary group gap-2"
            >
              View All Projects
              <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
              </svg>
            </a>
          </div>
        </div>
      </div>
    </section>

    <section id="blog" class="py-24 relative">
      <div class="container mx-auto px-4 md:px-8 relative z-10">
        <div class="text-center md:text-left mb-16 flex flex-col md:flex-row md:items-end gap-6 border-b border-white/10 pb-6">
          <h2 class="text-4xl md:text-5xl font-bold text-gray-100 tracking-tight flex items-center gap-4">
            <span class="text-brand-400 font-mono text-xl md:text-2xl font-normal">03.</span> 
            Latest Articles
          </h2>
          <div class="hidden md:block w-px h-8 bg-white/10 ml-4"></div>
          <span class="text-brand-400 font-mono text-sm tracking-wide">
            Writings & tutorials
          </span>
        </div>
        
        <div class="w-full">
          <ArticlesShowcase client:visible limit={3} />
          
          <div class="text-center mt-12">
            <a 
              href="/blog" 
              class="btn-secondary group gap-2"
            >
              View All Articles
              <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
              </svg>
            </a>
          </div>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>