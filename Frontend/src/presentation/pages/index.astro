---
import { Articles } from '../components/main/Articles';
import { Contact } from '../components/main/Contact';
import { Education } from '../components/main/Education';
import { Experience } from '../components/main/Experience';
import { Hero } from '../components/main/Hero';
import { Projects } from '../components/main/Projects';
import { Skills } from '../components/main/Skills';
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Petrus Handika - Full Stack Developer"
  description="Portfolio of Petrus Handika, a Full Stack Developer specializing in React, Next.js, Node.js, and modern web technologies."
>
  <main class="space-y-4 md:space-y-6 lg:space-y-8">
    <Hero />

    <section id="skills" class="py-4 md:py-6 lg:py-8 relative scroll-mt-20">
      <Skills client:visible />
    </section>

    <section id="experience" class="py-4 md:py-6 lg:py-8 relative scroll-mt-20">
      <Experience client:visible />
    </section>

    <section id="education" class="py-4 md:py-6 lg:py-8 relative scroll-mt-20">
      <Education client:visible />
    </section>

    <section id="projects" class="py-4 md:py-6 lg:py-8 relative scroll-mt-20">
      <div class="container mx-auto px-4 relative z-10">
        <div class="mb-6 md:mb-8 lg:mb-12 border-b border-white/10 py-6 w-full">
          <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold text-gray-100 tracking-tight flex items-center gap-3 md:gap-4 mb-3 md:mb-4">
            <span class="text-brand-400 font-mono text-lg md:text-xl lg:text-2xl font-normal">04.</span>
            Featured Projects
          </h2>
          <p class="text-base md:text-lg text-gray-400 font-light leading-relaxed">
            Some things I've built
          </p>
        </div>

        <div class="w-full">
          <Projects client:visible limit={6} />

          <div class="text-center mt-6 md:mt-8">
            <a href="/projects" class="btn-secondary group">
              View All Projects
            </a>
          </div>
        </div>
      </div>
    </section>

    <section id="blog" class="py-4 md:py-6 lg:py-8 relative scroll-mt-20">
      <div class="container mx-auto px-4 relative z-10">
        <div class="mb-6 md:mb-8 lg:mb-12 border-b border-white/10 py-6 w-full">
          <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold text-gray-100 tracking-tight flex items-center gap-3 md:gap-4 mb-3 md:mb-4">
            <span class="text-brand-400 font-mono text-lg md:text-xl lg:text-2xl font-normal">05.</span>
            Latest Articles
          </h2>
          <p class="text-base md:text-lg text-gray-400 font-light leading-relaxed">
            Writings & tutorials
          </p>
        </div>

        <div class="w-full">
          <Articles client:visible limit={3} />

          <div class="text-center mt-6 md:mt-8">
            <a href="/blog" class="btn-secondary group">View All Articles</a>
          </div>
        </div>
      </div>
    </section>

    <section id="contact" class="py-4 md:py-6 lg:py-8 relative scroll-mt-20">
      <Contact client:visible />
    </section>
  </main>
</BaseLayout>
