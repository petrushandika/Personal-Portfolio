---
import { Contact as ContactComponent } from '../../components/main/Contact';
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout 
  title="Contact - Petrus Handika"
  description="Get in touch with Petrus Handika for collaboration, freelance opportunities, or just to say hi."
>
  <main class="py-4 md:py-6 lg:py-8">
    <div class="absolute inset-0 bg-bg-base z-[-1]" />
    <div class="container mx-auto px-4 relative z-10">
      <div class="mb-6 md:mb-8 lg:mb-12 border-b border-white/10 py-6 w-full">
        <h1 class="text-3xl md:text-4xl lg:text-5xl font-bold text-gray-100 tracking-tight flex items-center gap-3 md:gap-4 mb-3 md:mb-4">
          <span class="text-brand-400 font-mono text-lg md:text-xl lg:text-2xl font-normal">06.</span> 
          Get In Touch
        </h1>
        <p class="text-base md:text-lg text-gray-400 font-light leading-relaxed">
          Have a project in mind or want to collaborate? I'd love to hear from you.
        </p>
      </div>
      
      <ContactComponent client:load />
    </div>
  </main>
</BaseLayout>
