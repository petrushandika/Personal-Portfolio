---
import { Contact as ContactComponent } from '../../components/main/Contact';
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout 
  title="Contact - Petrus Handika"
  description="Get in touch with Petrus Handika for collaboration, freelance opportunities, or just to say hi."
>
  <main class="py-24 relative overflow-hidden">
    <div class="absolute inset-0 bg-[#030014] z-[-1]" />
    
    <div class="mt-8">
      <ContactComponent client:visible />
    </div>
  </main>
</BaseLayout>
