---
import '../../styles/globals.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description || 'Personal Portfolio - Full Stack Developer'} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
  </head>
  <body class="font-sans antialiased text-gray-200 selection:bg-brand-500/30">
    <nav class="fixed top-0 left-0 right-0 z-50 bg-black/60 backdrop-blur-xl border-b border-white/5 transition-all duration-300">
      <div class="container mx-auto px-4 md:px-8">
        <div class="flex items-center justify-between h-16 md:h-20">
          <a href="/" class="text-xl md:text-2xl font-bold tracking-tight text-white">
            Petrus <span class="text-gray-400 font-light">Handika</span>
          </a>
          
          <div class="hidden md:flex items-center gap-8">
            <a href="/about" class="text-sm font-medium text-gray-400 hover:text-white transition-colors">About</a>
            <a href="/skills" class="text-sm font-medium text-gray-400 hover:text-white transition-colors">Skills</a>
            <a href="/experience" class="text-sm font-medium text-gray-400 hover:text-white transition-colors">Experience</a>
            <a href="/education" class="text-sm font-medium text-gray-400 hover:text-white transition-colors">Education</a>
            <a href="/projects" class="text-sm font-medium text-gray-400 hover:text-white transition-colors">Projects</a>
            <a href="/blog" class="text-sm font-medium text-gray-400 hover:text-white transition-colors">Blog</a>
            <a href="/contact" class="text-sm font-medium text-gray-400 hover:text-white transition-colors">Contact</a>
          </div>

          <div class="hidden md:flex items-center gap-4">
            <a 
              href="/contact" 
              class="hidden md:inline-flex btn-primary"
            >
              Let's Talk
            </a>
          </div>
        </div>
      </div>
    </nav>

    <div class="fixed inset-0 z-[-1] overflow-hidden">
      <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] md:w-[1000px] h-[600px] md:h-[1000px] bg-white/5 rounded-full blur-[140px] animate-blob animate-pulse"></div>
    </div>

    <slot />

    <footer class="bg-bg-card border-t border-white/5 text-gray-400 py-16 relative overflow-hidden">
      <!-- Glow effect in footer -->
      <div class="absolute top-0 left-1/2 -translate-x-1/2 w-full h-px bg-gradient-to-r from-transparent via-white/10 to-transparent"></div>
      
      <div class="container mx-auto px-4 md:px-8 relative z-10">
        <div class="grid md:grid-cols-4 gap-12">
          <div class="md:col-span-2">
            <h3 class="text-2xl font-bold mb-4 text-white">Petrus Handika</h3>
            <p class="mb-6 max-w-md leading-relaxed text-gray-400">
              Full-Stack Developer passionate about building beautiful, functional web applications. 
              Always eager to learn and create innovative solutions.
            </p>
            <div class="flex gap-4">
              <a href="https://github.com/petrushandika" target="_blank" class="text-gray-400 hover:text-white transition-colors">
                <span class="sr-only">GitHub</span><svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3.3 1.23c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
              </a>
              <a href="https://linkedin.com/in/petrushandika" target="_blank" class="text-gray-400 hover:text-white transition-colors">
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
              </a>
              <a href="https://twitter.com" target="_blank" class="text-gray-400 hover:text-white transition-colors">
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
              </a>
            </div>
          </div>
          
          <div>
            <h4 class="font-semibold mb-4 text-white">Quick Links</h4>
            <ul class="space-y-3">
              <li><a href="/about" class="hover:text-brand-400 transition-colors">About</a></li>
              <li><a href="/projects" class="hover:text-brand-400 transition-colors">Projects</a></li>
              <li><a href="/blog" class="hover:text-brand-400 transition-colors">Blog</a></li>
              <li><a href="/contact" class="hover:text-brand-400 transition-colors">Contact</a></li>
            </ul>
          </div>
          
          <div>
            <h4 class="font-semibold mb-4 text-white">Technologies</h4>
            <ul class="space-y-3">
              <li>React / Next.js</li>
              <li>Tailwind CSS</li>
              <li>Node.js / NestJS</li>
              <li>PostgreSQL / Redis</li>
            </ul>
          </div>
        </div>
        
        <div class="border-t border-white/10 mt-12 pt-8 text-center text-sm">
          <p>&copy; {new Date().getFullYear()} Petrus Handika. Crafted with passion.</p>
        </div>
      </div>
    </footer>
  </body>
</html>

<style is:global>
  html {
    scroll-behavior: smooth;
  }
  
  body {
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  }
</style>